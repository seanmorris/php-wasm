{
  "name": "php-dbg-wasm",
  "version": "0.1.0",
  "description": "phpdbg for wasm.",
  "main": "./PhpDbgNode.mjs",
  "module": "./PhpDbgNode.mjs",
  "types": "./PhpDbgNode.d.mts",
  "exports": {
    ".": {
      "types": "./PhpDbgNode.d.mts",
      "import": "./PhpDbgNode.mjs",
      "default": "./PhpDbgNode.mjs"
    },
    "./package.json": "./package.json",
    "./PhpDbgNode": {
      "types": "./PhpDbgNode.d.mts",
      "import": "./PhpDbgNode.mjs",
      "default": "./PhpDbgNode.mjs"
    },
    "./PhpDbgWeb": {
      "types": "./PhpDbgWeb.d.mts",
      "import": "./PhpDbgWeb.mjs",
      "default": "./PhpDbgWeb.mjs"
    },
    "./*.mjs": "./*.mjs",
    "./*.js": "./*.js",
    "./*.wasm": "./*.wasm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seanmorris/php-wasm.git"
  },
  "author": "Sean Morris <php-wasm@seanmorr.is>",
  "license": "Apache-2.0",
  "contributors": [
    {
      "name": "Sean Morris",
      "email": "php-wasm@seanmorr.is",
      "url": "https://seanmorr.is"
    }
  ],
  "dependencies": {
    "php-wasm": "^0.1.0"
  },
  "scripts": {
    "postpublish": "ls *.mjs *.js *.wasm *.data | while read FILENAME; do echo -n \"curl -X PURGE $FILENAME ... \";  curl -X PURGE https://cdn.jsdelivr.net/npm/php-wasm/$FILENAME; echo; done;"
  },
  "keywords": [
    "php",
    "wasm",
    "php-wasm",
    "php-dbg-wasm",
    "vrzno"
  ],
  "files": [
    "*.wasm",
    "*.d.mts",
    "LICENSE",
    "NOTICE",
    "README.md",
    "package.json",
    "libxml2.so",
    "PhpDbgNode.d.mts",
    "PhpDbgNode.mjs",
    "PhpDbgWeb.js",
    "PhpDbgWeb.mjs",
    "php*-dbg-node.mjs",
    "php-dbg-web.js",
    "php-dbg-web.mjs",
    "config.js",
    "config.mjs",
    "fsOps.js",
    "fsOps.mjs",
    "webTransactions.js",
    "webTransactions.mjs",
    "resolveDependencies.js",
    "resolveDependencies.mjs"
  ]
}
