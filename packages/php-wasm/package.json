{
  "name": "php-wasm",
  "version": "0.1.0",
  "description": "Run PHP right in the browser or anywhere else JS can run",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seanmorris/php-wasm.git"
  },
  "author": "Sean Morris<php-wasm@seanmorr.is>",
  "license": "Apache-2.0",
  "contributors": [
    {
      "name": "Sean Morris",
      "email": "php-wasm@seanmorr.is",
      "url": "https://seanmorr.is"
    },
    {
      "name": "Oraoto",
      "email": "oraoto@outlook.com"
    }
  ],
  "scripts": {
    "postpublish": "ls *.mjs *.js *.wasm *.data | while read FILENAME; do echo -n \"curl -X PURGE $FILENAME ... \";  curl -X PURGE https://cdn.jsdelivr.net/npm/php-wasm/$FILENAME; echo; done;"
  },
  "keywords": [
    "php",
    "wasm",
    "php-wasm",
    "vrzno"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./public": {
      "types": "./public.d.ts",
      "default": "./public.d.ts"
    },
    "./OutputBuffer": {
      "import": "./OutputBuffer.mjs",
      "default": "./OutputBuffer.mjs"
    },
    "./PhpBase": {
      "types": "./PhpBase.d.mts",
      "import": "./PhpBase.mjs",
      "require": "./PhpBase.js",
      "default": "./PhpBase.mjs"
    },
    "./PhpNode": {
      "types": "./PhpNode.d.mts",
      "import": "./PhpNode.mjs",
      "require": "./PhpNode.js",
      "default": "./PhpNode.mjs"
    },
    "./PhpWeb": {
      "types": "./PhpWeb.d.mts",
      "import": "./PhpWeb.mjs",
      "require": "./PhpWeb.js",
      "default": "./PhpWeb.mjs"
    },
    "./_Event": {
      "import": "./_Event.mjs",
      "default": "./_Event.mjs"
    },
    "./fsOps": {
      "import": "./fsOps.mjs",
      "default": "./fsOps.mjs"
    },
    "./resolveDependencies": {
      "import": "./resolveDependencies.mjs",
      "default": "./resolveDependencies.mjs"
    },
    "./webTransactions": {
      "import": "./webTransactions.mjs",
      "default": "./webTransactions.mjs"
    },
    "./php-tags": {
      "types": "./php-tags.d.mts",
      "import": "./php-tags.mjs",
      "default": "./php-tags.mjs"
    },
    "./php-tags.jsdelivr": {
      "types": "./php-tags.jsdelivr.d.mts",
      "import": "./php-tags.jsdelivr.mjs",
      "default": "./php-tags.jsdelivr.mjs"
    },
    "./php-tags.local": {
      "types": "./php-tags.local.d.mts",
      "import": "./php-tags.local.mjs",
      "default": "./php-tags.local.mjs"
    },
    "./php-tags.unpkg": {
      "types": "./php-tags.unpkg.d.mts",
      "import": "./php-tags.unpkg.mjs",
      "default": "./php-tags.unpkg.mjs"
    },
    "./*.mjs": "./*.mjs",
    "./*.js": "./*.js",
    "./*.wasm": "./*.wasm",
    "./*.data": "./*.data"
  },
  "files": [
    "*.js",
    "*.mjs",
    "[0-9a-f]*.wasm",
    "*.data",
    "*.d.ts",
    "*.d.mts",
    "LICENSE",
    "NOTICE",
    "README.md",
    "package.json",
    "stdlib/*.mjs",
    "mapped/*"
  ]
}
