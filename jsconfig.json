{
	"compilerOptions": {
		"checkJs": true,
		"target": "ESNext",
		"module": "esnext",
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"maxNodeModuleJsDepth": 0,
		"strict": false,
		"types": ["node"]
	},
	"include": ["source/**/*.js", "source/**/*.mjs", "source/**/*.d.ts", "packages/**/8.*.mjs", "packages/**/index.mjs"],
	"exclude": ["packages/php-wasm/stdlib/**/*"]
}
